{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aria",
  "version": "0.2.2",
  "identifier": "com.5060solutions.aria",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aria",
        "width": 420,
        "height": 720,
        "minWidth": 380,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "5060 Solutions",
    "copyright": "© 2024-2026 5060 Solutions. All rights reserved.",
    "category": "SocialNetworking",
    "shortDescription": "Modern open-source VoIP softphone",
    "longDescription": "Aria is a beautiful, modern softphone built from the ground up with Rust and React. Crystal-clear HD audio, secure TLS encryption, multi-account support, and built-in call recording. Free for personal use.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "certificateThumbprint": null,
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": {
        "language": "en-US"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"],
        "section": "comm"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["tel", "sip"]
      }
    }
  }
}
